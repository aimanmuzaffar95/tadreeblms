{
    "name": "rappasoft/laravel-boilerplate-upgraded",
    "description": "Laravel 10 Upgraded Project",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "barryvdh/laravel-dompdf": "^2.0",
        "barryvdh/laravel-translation-manager": "^0.6",
        "creativeorange/gravatar": "^1.0",
        "darryldecode/cart": "^4.2",
        "directorytree/ldaprecord": "3.8",
        "directorytree/ldaprecord-laravel": "3.4",
        "doctrine/dbal": "^3.7",
        "guzzlehttp/guzzle": "^7.8",
        "hashids/hashids": "^4.1",
        "jenssegers/agent": "^2.6",
        "laravel/cashier": "^15.0",
        "laravel/framework": "^10.48",
        "laravel/passport": "^12.0",
        "laravel/socialite": "^5.8",
        "laravel/tinker": "^2.8",
        "laravel/ui": "^4.2",
        "laravelcollective/html": "^6.4",
        "league/commonmark": "*",
        "league/flysystem-aws-s3-v3": "^3.0",
        "maatwebsite/excel": "^3.1",
        "paragonie/certainty": "^2.0",
        "phpmailer/phpmailer": "^6.9",
        "razorpay/razorpay": "^2.9",
        "sendgrid/sendgrid": "^7.0",
        "simplesoftwareio/simple-qrcode": "^4.2",
        "spatie/laravel-backup": "^9.0",
        "spatie/laravel-cookie-consent": "^3.3",
        "spatie/laravel-html": "^3.0",
        "spatie/laravel-ignition": "^2.0",
        "spatie/laravel-permission": "^6.0",
        "torann/geoip": "^3.0",
        "yajra/laravel-datatables-buttons": "^10.0",
        "yajra/laravel-datatables-oracle": "^10.0",
        "unisharp/laravel-filemanager": "^2.6"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^3.9",
        "fakerphp/faker": "^1.23",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^7.0",
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "app/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "dont-discover": [
                "spatie/laravel-backup"
            ]
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "@php artisan package:discover --ansi"
        ]
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}